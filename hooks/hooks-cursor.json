{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": "./hooks/session-start"
      }
    ],
    "postToolUse": [
      {
        "event": "Bash",
        "command": "./hooks/run-hook.cmd post-tool-trace"
      }
    ],
    "stop": [
      {
        "command": "./hooks/run-hook.cmd stop-reflect"
      }
    ]
  }
}
